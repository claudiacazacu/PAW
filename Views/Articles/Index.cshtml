@model Lab06.ViewModels.ArticleIndexViewModel

<h1>Știri</h1>

<p><a asp-action="Create" class="btn btn-primary">+ Adaugă articol</a></p>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var article in Model.Articles)
    {
        <div class="col">
            <div class="card h-100" style="cursor: pointer;">
                @if (article.ImagePath != null)
                {
                    <img src="@article.ImagePath" class="card-img-top" alt="@article.Title"
                         style="height: 200px; object-fit: cover;" />
                }
                <div class="card-body">
                    <h5 class="card-title fw-bold">
                        <a asp-action="Details" asp-route-id="@article.Id"
                           class="stretched-link text-decoration-none text-dark">@article.Title</a>
                    </h5>
                    <p class="card-text">
                        @(article.Content.Length > 100
                            ? article.Content[..100] + "..."
                            : article.Content)
                    </p>
                </div>
                <div class="card-footer" style="position: relative; z-index: 2;">
                    <small class="text-muted fst-italic">
                        @article.CategoryName — @article.PublishedAt.ToShortDateString()
                    </small>
                    <div class="mt-1">
                        <a asp-action="Edit" asp-route-id="@article.Id">Editează</a> |
                        <a asp-action="Delete" asp-route-id="@article.Id">Șterge</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<nav class="mt-4 d-flex justify-content-between align-items-center">
    @if (Model.CurrentPage > 1)
    {
        <a asp-action="Index" asp-route-page="@(Model.CurrentPage - 1)" class="btn btn-outline-secondary">← Pagina anterioară</a>
    }
    else
    {
        <span></span>
    }

    <span>Pagina @Model.CurrentPage din @Model.TotalPages</span>

    @if (Model.CurrentPage < Model.TotalPages)
    {
        <a asp-action="Index" asp-route-page="@(Model.CurrentPage + 1)" class="btn btn-outline-secondary">Pagina următoare →</a>
    }
    else
    {
        <span></span>
    }
</nav>
